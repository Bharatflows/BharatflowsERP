{
    "name": "bharatflow",
    "private": true,
    "workspaces": [
        "client",
        "server",
        "shared"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "npm run dev --workspace=@bharatflow/client",
        "dev:server": "npm run dev --workspace=bharatflow-server",
        "build": "npm run build --workspaces",
        "install:all": "npm install"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "baseline-browser-mapping": "^2.9.19",
        "concurrently": "^8.2.2",
        "shadcn": "^3.6.3"
    },
    "dependencies": {
        "@capacitor/android": "^7.4.4",
        "@capacitor/cli": "^8.0.2",
        "@capacitor/core": "^7.4.4",
        "@tanstack/react-table": "^8.21.3",
        "@typescript-eslint/eslint-plugin": "8.54.0",
        "@typescript-eslint/parser": "8.54.0",
        "cloudinary": "2.9.0",
        "eslint": "9.39.2",
        "html2pdf.js": "0.14.0",
        "jspdf": "4.1.0",
        "mongodb": "^7.0.0",
        "nodemailer": "7.0.13",
        "vite": "7.3.1"
    }
}
