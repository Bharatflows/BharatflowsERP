{
    "name": "bharatflow",
    "private": true,
    "workspaces": [
        "client",
        "server",
        "shared"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "npm run dev --workspace=@bharatflow/client",
        "dev:server": "npm run dev --workspace=bharatflow-server",
        "build": "npm run build --workspaces",
        "install:all": "npm install"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "@capacitor/android": "^7.4.4",
        "@capacitor/cli": "^7.4.4",
        "@capacitor/core": "^7.4.4",
        "mongodb": "^7.0.0"
    }
}
