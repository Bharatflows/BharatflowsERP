generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String  @id @default(uuid())
  businessName    String
  legalName       String?
  legalType       String? // Proprietorship, Partnership, LLP, etc.
  yearEstablished Int?
  employeesCount  String? // 1-10, 11-50, etc.

  // P0-4: Business Classification (MANDATORY)
  businessType           String? // Manufacturing, Trading, Service, Hybrid
  city                   String? // City for location indexing
  state                  String? // State for location indexing
  classificationLockedAt DateTime? // Once set, classification cannot be changed

  // MSME OS: Sector configuration
  sector      String?   // e.g., "GARMENT", "POLYBAG", "FOOD_PROCESSING"
  subSector   String?   // e.g., "KNITTED_GARMENT", "WOVEN"
  sectorConfig String?    // Stores sector-specific settings applied during setup

  // Business Profile Relations
  primaryCategoryId String?
  primaryCategory   BusinessCategory? @relation(fields: [primaryCategoryId], references: [id])

  industries         Industry[] // Many-to-many
  businessActivities BusinessActivity[] // Many-to-many: Manufacturer, Wholesaler etc.
  businessProducts   BusinessProduct[] // Many-to-many
  capabilities       BusinessCapability[] // Many-to-many

  // P0-2: GSTIN moved to Branch model (kept for backwards compatibility during migration)
  gstin              String?             @unique
  pan                String?
  email              String?
  phone              String?
  address            String?
  bankDetails        String?
  logo               String?
  fiscalYear         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  features           String?
  enabledModules     String?               @default("{}")
  plan               String                @default("FREE")
  approvalWorkflows  ApprovalWorkflow[]
  approvalRequests   ApprovalRequest[]
  auditLogs          AuditLog[]
  bankAccounts       BankAccount[]
  categories         Category[]
  conversations      Conversation[]
  deliveryChallans   DeliveryChallan[]
  devices            Device[]
  eInvoices          EInvoice[]
  eWaybills          EWaybill[]
  employees          Employee[]
  estimates          Estimate[]
  expenses           Expense[]
  gstPayments        GSTPayment[]
  goodsReceivedNotes GoodsReceivedNote[]
  ipWhitelists       IPWhitelist[]
  invites            Invite[]
  invoices           Invoice[]
  parties            Party[]
  paymentReminders   PaymentReminder[]
  products           Product[]
  purchaseBills      PurchaseBill[]
  purchaseOrders     PurchaseOrder[]
  quotations         Quotation[]
  salesOrders        SalesOrder[]
  sequences          Sequence[]
  stockMovements     StockMovement[]
  transactions       Transaction[]
  units              Unit[]
  users              User[] // Legacy: direct users (kept for migration)
  userCompanies      UserCompany[] // P0-1: Multi-company user memberships
  branches           Branch[] // P0-2: Multi-branch/GSTIN support
  warehouses         Warehouse[]
  domainEvents       DomainEvent[] // P0-5: Domain event log
  syncConflicts      SyncConflict[] // P0-9: Offline sync conflicts

  // ERP Module Relations
  leads            Lead[]
  activities       Activity[]
  attendances      Attendance[]
  leaves           Leave[]
  salaryStructures SalaryStructure[]
  payrollRuns      PayrollRun[]
  ledgerGroups     LedgerGroup[]
  ledgers          Ledger[]
  vouchers         Voucher[]
  posSessions      POSSession[]

  stockBatches      StockBatch[]
  creditNotes       CreditNote[]
  debitNotes        DebitNote[]
  receipts          Receipt[] // P2: Multi-invoice Payment Allocation
  stockAdjustments  StockAdjustment[]
  expenseCategories ExpenseCategory[]
  customRoles       CustomRole[]

  // Production
  billOfMaterials    BillOfMaterial[]
  workOrders         WorkOrder[]
  productionPlans    ProductionPlan[]
  qualityInspections QualityInspection[]

  postDatedCheques     PostDatedCheque[]
  maintenanceSchedules MaintenanceSchedule[]
  financialYears       FinancialYear[] // P0: Financial Year Locking
  financialPeriods     FinancialPeriod[]
  notifications        Notification[]
  recurringProfiles    RecurringInvoiceProfile[]

  // Company Settings
  valuationMethod String @default("AVERAGE") // FIFO, WEIGHTED_AVERAGE, AVERAGE

  // Subscription & Payment Gateway
  subscriptions         Subscription[]
  paymentGatewayConfigs PaymentGatewayConfig[]

  // Settings Audit & Approval
  settingsAuditLogs          SettingsAuditLog[]
  settingsApprovalRequests   SettingsApprovalRequest[]
  wastageLogs                WastageLog[]
  
  // Channel Hub (E-commerce Aggregation)
  channelConfigs    ChannelConfig[]
  channelOrders     ChannelOrder[]

  // New Modules (Prompts 3, 5, 6, 7)
  rfqs                   RFQ[]
  supplierQuotes         SupplierQuote[]
  groupBuyParticipations GroupBuyParticipation[]
  shipments              Shipment[]
  escrowTransactions     EscrowTransaction[]
  initiatedGroupBuys     GroupBuyIntent[]    @relation("GroupBuyInitiator")
  
  // New ERP Modules
  costCenters      CostCenter[]
  projects         Project[]
  assets           Asset[]
  assetCategories  AssetCategory[]

  // Sprint 1: Multi-Currency & Advanced Accounting
  currencies       Currency[]
  budgets          Budget[]

  // Sprint 2: Manufacturing enhancements
  jobCards         JobCard[]

  // Sprint 4: Quality & Support
  slas             SLA[]
  issues           Issue[]

  // Sprint 5: Projects & Timesheets
  timesheets       Timesheet[]

  // Sprint 6: Advanced Features
  subcontractingOrders SubcontractingOrder[]
  stockReconciliations StockReconciliation[]

  @@index([businessType])
  @@index([city])
  @@index([state])
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  budget      Decimal  @default(0)
  color       String   @default("#6b7280")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Policy Limits
  maxAmount Decimal? // Maximum amount per expense in this category

  // Accounting Integration
  ledgerId String?
  ledger   Ledger? @relation(fields: [ledgerId], references: [id])

  @@unique([companyId, name])
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  name               String
  phone              String?   @unique
  role               String      @default("STAFF") // P0-3: Default to STAFF
  status             String    @default("ACTIVE")
  emailVerified      Boolean   @default(false)
  phoneVerified      Boolean   @default(false)
  lastActive         DateTime?
  lastLogin          DateTime?
  // Password Reset Fields
  resetToken         String?
  resetTokenExpiry   DateTime?
  // OTP Fields
  otp                String?
  otpExpiry          DateTime?
  // Refresh Token Fields
  refreshToken       String?
  refreshTokenExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // P0-1: Legacy companyId kept for migration, new flow uses UserCompany
  companyId    String? // Made optional for multi-company support
  moduleAccess String?

  // Profile Fields
  designation          String?
  avatar               String?
  bio                  String?
  signature            String? // URL to signature image
  preferences          String? // { theme, language, timezone, dateFormat }
  notificationSettings String? // { email: {}, mobile: {} }

  // Custom String Relation
  customRoleId String?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])

  // Two-Factor Authentication (2FA)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?  // Encrypted TOTP secret
  twoFactorBackup  String?    // Backup codes array
  twoFactorMethod  String?  // TOTP, SMS, EMAIL

  conversationParticipants ConversationParticipant[]
  devices                  Device[]
  invitesSent              Invite[]                  @relation("InvitesSent")
  invoices                 Invoice[]
  messages                 Message[]
  messageReads             MessageRead[]
  company                  Company?                  @relation(fields: [companyId], references: [id]) // Made optional
  userCompanies            UserCompany[] // P0-1: Multi-company memberships
  posSessions              POSSession[]
  approvedExpenses         Expense[]                 @relation("ExpenseApprover")
  syncConflicts            SyncConflict[] // P0-9: Offline sync conflicts
  notifications            Notification[]

  // Settings Audit & Approval Relations
  settingsAuditLogs          SettingsAuditLog[]
  requestedApprovals         SettingsApprovalRequest[] @relation("RequestedApprovals")
  approvedApprovalRequests   SettingsApprovalRequest[] @relation("ApprovedRequests")
  
  // Transaction Approvals (P0-8)
  transactionRequests        ApprovalRequest[] @relation("TransactionRequests")
  transactionApprovals       ApprovalRequest[] @relation("TransactionApprovals")
}

// System Notifications (Low Stock, Payment Due, etc.)
model Notification {
  id        String    @id @default(uuid())
  type      String // LOW_STOCK, PAYMENT_DUE, ORDER_RECEIVED, SYSTEM
  title     String
  message   String
  data      String? // { entityId, entityType, actionUrl }
  read      Boolean   @default(false)
  readAt    DateTime?
  userId    String
  companyId String
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([userId, read])
  @@index([companyId, createdAt])
}

model Product {
  id               String   @id @default(uuid())
  name             String
  code             String?
  hsnCode          String?
  description      String?
  unit             String
  purchasePrice    Decimal  @default(0)
  sellingPrice     Decimal  @default(0)
  mrp              Decimal?
  gstRate          Decimal  @default(0)
  currentStock     Int      @default(0)
  minStock         Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  companyId        String
  barcode          String?
  category         String?
  location         String?
  maxStock         Int      @default(0)
  reorderLevel     Int      @default(0)
  sellWithoutStock Boolean  @default(false)
  taxInclusive     Boolean  @default(false)
  trackInventory   Boolean  @default(true)

  // New Inventory Features
  isBatchTracked  Boolean        @default(false)
  isSerialTracked Boolean        @default(false)
  batches         StockBatch[]
  serialNumbers   SerialNumber[]

  // BOM Relations
  asFinishedProduct BillOfMaterial[] @relation("FinishedProduct")
  asRawMaterial     BOMItem[]        @relation("RawMaterial")

  deliveryChallanItems   DeliveryChallanItem[]
  estimateItems          EstimateItem[]
  goodsReceivedNoteItems GoodsReceivedNoteItem[]
  invoiceItems           InvoiceItem[]
  company                Company                 @relation(fields: [companyId], references: [id])
  purchaseBillItems      PurchaseBillItem[]
  purchaseOrderItems     PurchaseOrderItem[]
  quotationItems         QuotationItem[]
  salesOrderItems        SalesOrderItem[]
  stockMovements         StockMovement[]
  creditNoteItems        CreditNoteItem[]
  debitNoteItems         DebitNoteItem[]
  qualityInspections     QualityInspection[]

  maintenanceSchedules   MaintenanceSchedule[]
  stockAdjustmentItems   StockAdjustmentItem[]
  wastageLogs            WastageLog[]
  rfqItems               RFQItem[]
  supplierQuoteItems     SupplierQuoteItem[]
}

model Party {
  id                       String                    @id @default(uuid())
  name                     String
  type                     String
  gstin                    String?
  pan                      String?
  email                    String?
  phone                    String?
  billingAddress           String?
  shippingAddress          String?
  openingBalance           Decimal                   @default(0)
  currentBalance           Decimal                   @default(0)
  isActive                 Boolean                   @default(true)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  companyId                String
  msmeType                 String?
  udyamNumber              String?
  conversationParticipants ConversationParticipant[]
  deliveryChallans         DeliveryChallan[]
  estimates                Estimate[]
  goodsReceivedNotes       GoodsReceivedNote[]
  invites                  Invite[]
  invoices                 Invoice[]
  company                  Company                   @relation(fields: [companyId], references: [id])
  paymentReminders         PaymentReminder[]
  purchaseBills            PurchaseBill[]
  purchaseOrders           PurchaseOrder[]
  quotations               Quotation[]
  salesOrders              SalesOrder[]
  activities               Activity[]
  ledger                   Ledger?
  creditNotes              CreditNote[]

  // Escrow Relations
  escrowPayer     EscrowTransaction[] @relation("EscrowPayer")
  escrowPayee     EscrowTransaction[] @relation("EscrowPayee")
  supplierQuotes  SupplierQuote[]


  debitNotes               DebitNote[]
  receipts                 Receipt[] // P2: Multi-invoice Payment Allocation
  postDatedCheques         PostDatedCheque[]
  recurringProfiles        RecurringInvoiceProfile[]
  creditPeriod             Int                       @default(0) // Default credit days
  channelOrders            ChannelOrder[]
  creditScore              Int                       @default(0) // CRM: 0-100 score based on payment history

  // Subcontracting Relations
  subcontractingOrders     SubcontractingOrder[]

  // Project Relations
  projects                 Project[]

  // Ledger Posting Relations
  ledgerPostings           LedgerPosting[]
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String
  invoiceDate    DateTime
  dueDate        DateTime?
  subtotal       Decimal
  totalTax       Decimal
  totalAmount    Decimal
  amountPaid     Decimal       @default(0)
  balanceAmount  Decimal
  discountAmount Decimal       @default(0)
  roundOff       Decimal       @default(0)
  status         String @default("DRAFT")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  companyId      String
  userId         String
  customerId     String
  branchId       String? // P0-2: Branch for GSTIN
  deletedAt      DateTime? // P1: Soft delete support

  // P0: GST Compliance Fields
  placeOfSupply   String? // State code e.g., "27" for Maharashtra
  isReverseCharge Boolean @default(false)
  isInterState    Boolean @default(false) // Auto-calculated from placeOfSupply

  // P0-1: Detailed Tax Breakdown (Header Level)
  cgst Decimal?
  sgst Decimal?
  igst Decimal?

  // P0: Approval Workflow Fields
  approvalStatus  String    @default("APPROVED") // PENDING, APPROVED, REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  company            Company             @relation(fields: [companyId], references: [id])
  customer           Party               @relation(fields: [customerId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  branch             Branch?             @relation("BranchInvoices", fields: [branchId], references: [id])
  items              InvoiceItem[]
  creditNotes        CreditNote[]
  eInvoice           EInvoice?
  eWaybill           EWaybill?
  receiptAllocations ReceiptAllocation[] // P2: Multi-invoice Payment Allocation
  paymentReminders   PaymentReminder[]

  recurringProfileId String?
  recurringProfile   RecurringInvoiceProfile? @relation(fields: [recurringProfileId], references: [id])
  channelOrders      ChannelOrder[]
  shipments          Shipment[]
  escrowTransaction  EscrowTransaction?

  @@unique([companyId, invoiceNumber])
  @@index([branchId])
  @@index([approvalStatus])
  @@index([companyId, invoiceDate])
  @@index([companyId, status])
}

// P2: Multi-Invoice Payment Allocation Models
model Receipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  date          DateTime
  amount        Decimal
  unusedAmount  Decimal
  paymentMethod String // CASH, BANK, UPI, CHEQUE, ONLINE
  reference     String?
  notes         String?
  status        String   @default("COMPLETED") // COMPLETED, CANCELLED

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  customerId String
  customer   Party  @relation(fields: [customerId], references: [id])

  allocations ReceiptAllocation[]

  // Accounting Link
  voucherId String?  @unique
  voucher   Voucher? @relation(fields: [voucherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, receiptNumber])
  @@index([companyId, date])
  @@index([customerId])
}

model ReceiptAllocation {
  id     String   @id @default(uuid())
  amount Decimal
  date   DateTime @default(now())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([receiptId, invoiceId])
  @@index([invoiceId])
}

model RecurringInvoiceProfile {
  id          String    @id @default(uuid())
  profileName String
  frequency   String // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  startDate   DateTime
  nextRunDate DateTime
  lastRunDate DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)

  // Invoice Template Data
  customerId String
  customer   Party   @relation(fields: [customerId], references: [id])
  items      String // Store items snapshot
  terms      String?
  notes      String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedInvoices Invoice[]

  @@index([companyId, isActive])
  @@index([nextRunDate])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  quantity    Int
  rate        Decimal
  taxRate     Decimal
  taxAmount   Decimal
  cgst        Decimal? @default(0)
  sgst        Decimal? @default(0)
  igst        Decimal? @default(0)
  total       Decimal
  invoiceId   String
  productId   String?
  productName String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  // Batch Reference
  batchId String?
  batch   StockBatch? @relation(fields: [batchId], references: [id])
}

model CreditNote {
  id               String   @id @default(uuid())
  creditNoteNumber String
  date             DateTime
  invoiceId        String?
  customerId       String

  subtotal    Decimal
  totalTax    Decimal
  totalAmount Decimal

  type   String  @default("RETURN") // RETURN, FINANCIAL
  reason String?
  status String  @default("DRAFT")

  invoice  Invoice?         @relation(fields: [invoiceId], references: [id])
  customer Party            @relation(fields: [customerId], references: [id])
  items    CreditNoteItem[]

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, creditNoteNumber])
}

model CreditNoteItem {
  id           String  @id @default(uuid())
  creditNoteId String
  productId    String?
  quantity     Int
  rate         Decimal
  taxRate      Decimal
  taxAmount    Decimal
  total        Decimal
  reason       String?

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])
}

model DebitNote {
  id              String   @id @default(uuid())
  debitNoteNumber String
  date            DateTime
  billId          String?
  supplierId      String

  subtotal    Decimal
  totalTax    Decimal
  totalAmount Decimal

  type   String  @default("RETURN") // RETURN, FINANCIAL
  reason String?
  status String  @default("DRAFT")

  bill     PurchaseBill?   @relation(fields: [billId], references: [id])
  supplier Party           @relation(fields: [supplierId], references: [id])
  items    DebitNoteItem[]

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, debitNoteNumber])
}

model DebitNoteItem {
  id          String  @id @default(uuid())
  debitNoteId String
  productId   String?
  quantity    Int
  rate        Decimal
  taxRate     Decimal
  taxAmount   Decimal
  total       Decimal
  reason      String?

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
}

model Expense {
  id            String    @id @default(uuid())
  expenseNumber String?
  category      String
  amount        Decimal
  date          DateTime
  description   String?
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  deletedAt     DateTime? // P1: Soft delete support
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  companyId     String
  gstAmount     Decimal   @default(0)
  notes         String?
  paymentMethod String?
  receiptUrl    String?
  vendor        String?

  // Approval Workflow
  approvedById    String?
  approvedBy      User?     @relation("ExpenseApprover", fields: [approvedById], references: [id])
  approvalDate    DateTime?
  rejectionReason String?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, expenseNumber])
  @@index([companyId, date])
  @@index([companyId, status])
}

model PurchaseOrder {
  id                    String              @id @default(uuid())
  orderNumber           String
  supplierInvoiceNumber String?
  orderDate             DateTime
  billDate              DateTime?
  expectedDate          DateTime?
  subtotal              Decimal
  totalTax              Decimal
  totalAmount           Decimal
  paidAmount            Decimal             @default(0)
  status                String              @default("DRAFT")
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  companyId             String
  supplierId            String
  company               Company             @relation(fields: [companyId], references: [id])
  supplier              Party               @relation(fields: [supplierId], references: [id])
  items                 PurchaseOrderItem[]

  // Procurement Links (Prompt 5)
  rfqId                 String?
  rfq                   RFQ?                @relation(fields: [rfqId], references: [id])
  quoteId               String?
  quote                 SupplierQuote?      @relation(fields: [quoteId], references: [id])
  shipments             Shipment[]

  @@unique([companyId, orderNumber])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  quantity         Int
  receivedQuantity Int           @default(0)
  rate             Decimal
  taxRate          Decimal
  taxAmount        Decimal
  total            Decimal
  purchaseOrderId  String
  productId        String?
  productName      String
  product          Product?      @relation(fields: [productId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Employee {
  id               String    @id @default(uuid())
  employeeId       String
  name             String
  email            String
  phone            String
  department       String
  designation      String
  joiningDate      DateTime
  dateOfBirth      DateTime?
  salary           Decimal
  accountNumber    String?
  ifscCode         String?
  panNumber        String?
  aadhaarNumber    String?
  pfNumber         String?
  esiNumber        String?
  address          String?
  emergencyContact String?
  emergencyName    String?
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])

  attendance      Attendance[]
  leaves          Leave[]
  salaryStructure SalaryStructure?
  payrollSlips    PayrollRun[]

  @@unique([companyId, employeeId])
  @@unique([companyId, email])
}

model BankAccount {
  id             String    @id @default(uuid())
  name           String
  bankName       String
  accountNumber  String
  ifsc           String
  type           String
  balance        Decimal   @default(0)
  status         String    @default("ACTIVE")
  lastReconciled DateTime?

  // Banking Integration Fields
  provider          String? // RAZORPAY, SETU, PLIAD, etc.
  providerAccountId String? // External ID from provider
  syncActive        Boolean   @default(false)
  lastSyncAt        DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  transactions Transaction[]
  ledger       Ledger?
}

model Transaction {
  id          String      @id @default(uuid())
  date        DateTime
  description String
  category    String
  amount      Decimal
  type        String
  status      String      @default("CLEARED")
  reference   String?
  externalId  String?     @unique // ID from bank provider to prevent duplicates
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  companyId   String
  accountId   String
  account     BankAccount @relation(fields: [accountId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id])
}

model PaymentReminder {
  id            String   @id @default(uuid())
  companyId     String
  partyId       String 
  invoiceId     String 
  
  type          String // OVERDUE, etc.
  status        String // PENDING, SENT, FAILED
  message       String
  scheduledFor  DateTime
  sentAt        DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  company       Company @relation(fields: [companyId], references: [id])
  party         Party   @relation(fields: [partyId], references: [id])
  invoice       Invoice @relation(fields: [invoiceId], references: [id])
  
  @@index([companyId, status])
  @@index([invoiceId])
}

model Estimate {
  id             String         @id @default(uuid())
  estimateNumber String
  date           DateTime
  validUntil     DateTime
  subtotal       Decimal
  totalTax       Decimal
  totalAmount    Decimal
  status         String         @default("PENDING")
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  companyId      String
  customerId     String
  company        Company        @relation(fields: [companyId], references: [id])
  customer       Party          @relation(fields: [customerId], references: [id])
  items          EstimateItem[]

  @@unique([companyId, estimateNumber])
}

model EstimateItem {
  id          String   @id @default(uuid())
  quantity    Int
  rate        Decimal
  taxRate     Decimal
