PORT=5001
# PostgreSQL (Docker Local)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/bharatflow_db?schema=public&sslmode=disable"
# DATABASE_URL="file:./dev.db"

# MongoDB Atlas (Cloud) - REPLACE THIS WITH YOUR ATLAS CONNECTION STRING
MONGODB_URI="mongodb+srv://deepaknehru:Dneepak%40123@cluster0.dlrzktt.mongodb.net/?appName=Cluster0"

JWT_SECRET=bharatflow_secret_key_change_this_in_production
JWT_REFRESH_SECRET=bharatflow_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=production
CLIENT_URL=https://www.bharatflows.com
CORS_ORIGINS=https://www.bharatflows.com,http://localhost:5173
API_VERSION=v1

# GST Integration
# Set to "sandbox" for launch (safe mock mode). Switch to "live" once GST credentials are obtained.
GST_PORTAL_MODE=sandbox
# GST_LIVE_API_KEY=  # Intentionally unset — configure when upgrading to live mode
# GST_LIVE_API_URL=https://api.e-invoice.gst.gov.in

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Encryption Key (32 bytes = 64 hex chars) - KEEP SECRET!
ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# Redis Configuration (set to true to enable job queues)
REDIS_ENABLED=false
