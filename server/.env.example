# Example environment variables (rename to .env in development, DO NOT commit secrets)

# Postgres
DATABASE_URL=postgresql://msme:msme_pass@localhost:5432/msme_db

# MongoDB
MONGODB_URI=mongodb://localhost:27017/msme_db

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILI_MASTER_KEY=masterKey
MEILI_HOST=http://localhost:7700

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=msme-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# JWT / Auth
JWT_SECRET=replace_with_secure_random_value

# Mail service
EMAIL_FROM=no-reply@yourdomain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Admins
PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin
