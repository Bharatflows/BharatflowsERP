{
  "name": "bharatflow-server",
  "version": "1.0.0",
  "description": "BharatFlow MSME Operating System - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "backup": "ts-node scripts/backup-database.ts",
    "restore": "ts-node scripts/restore-database.ts",
    "check-data": "ts-node scripts/check-data-integrity.ts",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:safe": "npm run backup && npx prisma migrate dev",
    "migrate:deploy:safe": "npm run backup && npx prisma migrate deploy"
  },
  "keywords": [
    "msme",
    "erp",
    "invoicing",
    "gst",
    "india"
  ],
  "author": "BharatFlow",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/pg": "^8.15.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^11.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.13.0",
    "pg": "^8.16.3",
    "prisma": "^5.7.0",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.9",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "axios": "^1.13.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
