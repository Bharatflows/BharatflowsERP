{
  "name": "bharatflows-server",
  "version": "1.0.0",
  "description": "BharatFlows MSME Operating System - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "backup": "ts-node scripts/backup-database.ts",
    "restore": "ts-node scripts/restore-database.ts",
    "check-data": "ts-node scripts/check-data-integrity.ts",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:safe": "npm run backup && npx prisma migrate dev",
    "migrate:deploy:safe": "npm run backup && npx prisma migrate deploy"
  },
  "keywords": [
    "msme",
    "erp",
    "invoicing",
    "gst",
    "india"
  ],
  "author": "BharatFlows",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/pg": "^8.15.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.66.4",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^11.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^7.1.0",
    "html2pdf.js": "0.14.0",
    "ioredis": "^5.8.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "4.1.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.13",
    "resend": "^4.0.0",
    "pdfkit": "^0.13.0",
    "pg": "^8.16.3",
    "prisma": "^5.7.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "vite": "7.3.1",
    "winston": "^3.11.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "axios": "^1.13.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
